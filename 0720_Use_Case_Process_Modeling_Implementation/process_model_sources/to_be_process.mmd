flowchart TB
    subgraph OWNER["泳道：攤主"]
        direction TB
        B((開始：準備申請)) --> C1["T-C1 填寫攤位申請"]
        C2["T-C2 依欄位提示修正"]
        C3["T-C3 查看申請編號、送件時間與審核中狀態"]
        C4["T-C4 查看通過／退回與完整意見"]
        D3{"T-D3 是否立即補正？"}
        C5["T-C5 修改原申請並重送"]
        EC((替代結束：維持退回，日後再補正))
        C6["T-C6 查看位置公告"]
    end

    subgraph SYS["泳道：系統"]
        direction TB
        S1["T-S1 驗證必填與格式"] --> D1{"T-D1 資料有效？"}
        S2["T-S2 建立申請編號、時間、審核中狀態並同步待審清單"]
        D2{"T-D2 退回意見有效？"}
        S3["T-S3 拒絕退回；保持審核中"]
        S4["T-S4 保存退回結果與完整意見"]
        S5["T-S5 保存通過結果並移出待審"]
        S6["T-S6 同編號重送、重送次數 +1、回到審核中"]
        D4{"T-D4 格位已占用？"}
        S7["T-S7 拒絕新配置並保留原配置"]
        S8["T-S8 保存人工選定的配置"]
        S9["T-S9 由同一配置資料提供公開結果文字與靜態地圖標記"]
        D6{"T-D6 有完整值相符資料？"}
        S10["T-S10 顯示 0 筆、無結果訊息並清除舊標記"]
        S11["T-S11 顯示編號、位置與一致標記；不顯示 email"]
    end

    subgraph ORG["泳道：主辦方承辦人"]
        direction TB
        O1["T-O1 開啟待審案件並人工判斷"]
        O2{"T-D2a 通過或退回？"}
        O3["T-O3 補填有效退回意見"]
        O4["T-O4 人工選擇攤位格位"]
        O5["T-O5 人工改選其他格位"]
        D5{"T-D5 是否需臨時調整？"}
        O6["T-O6 人工修改配置"]
    end

    subgraph VIS["泳道：一般參加者"]
        direction TB
        A1["T-A1 輸入完整攤名／編號／作品類型"]
        A2["T-A2 修正完整值或轉人工詢問"]
        A3["T-A3 依文字位置與靜態標記前往"]
        D7{"T-D7 現場能找到？"}
        EA((結束 A：找到攤位))
    end

    subgraph STAFF["泳道：現場工作人員"]
        direction TB
        F1["T-F1 使用同一公開靜態配置"]
        F2["T-F2 接受參加者詢問"]
        D8{"T-D8 能確認位置？"}
        F3["T-F3 口頭指引參加者"]
        F4["T-F4 回問主辦方／現場查證"]
        EB((結束 B：仍無法及時確認))
    end

    C1 -. "H1 送件" .-> S1
    D1 -->|否／例外 E1| C2 --> C1
    D1 -->|是| S2
    S2 -. "H2 收件結果" .-> C3
    S2 -. "H3 待審資料" .-> O1 --> O2
    O2 -->|退回| D2
    D2 -->|否／例外 E2| S3 -.-> O3 --> O2
    D2 -->|是| S4 -.-> C4 --> D3
    D3 -->|否／替代 A1| EC
    D3 -->|是| C5 -.-> S6 -.-> O1
    O2 -->|通過| S5 -.-> O4
    O4 -. "人工配置" .-> D4
    D4 -->|是／例外 E3| S7 -.-> O5 --> O4
    D4 -->|否| S8 -.-> D5
    D5 -->|是| O6 -.-> D4
    D5 -->|否| S9
    S9 -.-> C6
    S9 -. "H4 公開配置" .-> A1
    S9 -.-> F1
    A1 -. "H5 查詢" .-> D6
    D6 -->|否／例外 E4| S10 -.-> A2
    A2 --> A1
    A2 -. "人工詢問" .-> F2
    D6 -->|是| S11 -.-> A3 --> D7
    D7 -->|是| EA
    D7 -->|否| F2 --> D8
    D8 -->|能| F3 -.-> EA
    D8 -->|不能| F4 --> EB

    I1["改善 I1／P1：即時收件與可查狀態"]:::improve -.-> S2
    I2["改善 I2／P2：欄位驗證與待審同步"]:::improve -.-> S1
    I3["改善 I3／P3：拒絕重複並保留原配置"]:::improve -.-> S7
    I4["改善 I4／P4：結果文字與靜態標記共用配置資料"]:::improve -.-> S9
    I5["改善 I5／P5：完整值查攤與人工備援"]:::improve -.-> S11

    classDef improve fill:#ecfdf5,stroke:#059669,stroke-width:2px,color:#064e3b;
    classDef decision fill:#fffbeb,stroke:#d97706,stroke-width:2px,color:#451a03;
    class D1,D2,D3,D4,D5,D6,D7,D8,O2 decision;

