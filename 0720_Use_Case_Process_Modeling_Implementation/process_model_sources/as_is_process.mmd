flowchart TB
    subgraph OWNER["泳道：攤主"]
        direction TB
        S((開始：準備申請)) --> C1["C1 閱讀簡章並準備資料"]
        C1 --> C2["C2 以 Google 表單或 email 送件"]
        C2A["C2a 補齊缺漏資料並由原管道重送"]
        C3["C3 等待 email／社群結果"] --> C4{"D3 是否收到結果？"}
        C4 -->|否| C4N["C4 繼續等待或另行確認"] --> C3
        C4 -->|是| C5{"D4 審核結果？"}
        C5 -->|退回| C6["C5 依通知補資料並由原管道重送"]
        C5 -->|通過| C7["C6 等待位置公告"]
    end

    subgraph ORG["泳道：主辦方承辦人"]
        direction TB
        O1["O1 接收表單／email 申請"] --> O2["O2 人工複製、彙整至試算表"]
        O2 --> D1{"D1 資料是否完整？"}
        D1 -->|否| O3["O3 以 email／社群通知補資料"]
        D1 -->|是| O4["O4 人工審核並記錄結果"]
        O4 --> D2{"D2 是否通過？"}
        D2 -->|否| O5R["O5a 通知退回與補充要求"]
        D2 -->|是| O5P["O5b 通知通過"] --> O6["O6 在試算表手動排位"]
        O6 --> D3{"D5 人工檢查是否重複格位？"}
        D3 -->|有| O7["O7 人工重新調整位置"] --> O6
        D3 -->|無| O8["O8 匯出攤位配置表"]
        O8 --> D4{"D6 是否有臨時異動？"}
        D4 -->|有| O9["O9 人工修改公告／配置副本"] --> O10["O10 發布紙本場刊／社群公告並交付配置表"]
        D4 -->|無| O10
    end

    subgraph VIS["泳道：一般參加者"]
        direction TB
        A1["A1 查閱紙本場刊或社群公告"] --> D5{"D7 資訊是否與現場一致？"}
        D5 -->|是| A2["A2 依編號與位置前往攤位"] --> E1((結束 A：找到攤位))
        D5 -->|否| A3["A3 詢問現場工作人員"]
    end

    subgraph STAFF["泳道：現場工作人員"]
        direction TB
        T1["S1 查看主辦方提供的配置表"] --> D6{"D8 手上版本能否確認位置？"}
        D6 -->|能| T2["S2 口頭指引參加者"]
        D6 -->|不能| T3["S3 回問主辦方／現場查證"] --> E2((結束 B：無法及時確認))
    end

    C2 -. "H1 角色交接：表單／email" .-> O1
    O3 -. "H2 缺漏補件通知" .-> C2A
    C2A -. "原管道重送" .-> O1
    O5R -. "H2 審核結果" .-> C3
    O5P -. "H2 審核結果" .-> C3
    O5R -. "退回補充要求" .-> C6
    C6 -. "原管道重送" .-> O1
    O10 -. "H3 公告／配置表" .-> C7
    O10 -. "H3 公告" .-> A1
    O10 -. "H3 配置表" .-> T1
    A3 -. "H4 口頭詢問" .-> D6
    T2 -. "指引" .-> A2

    P1["痛點 P1：等待不透明、擔心漏件"]:::pain -.-> C3
    P2["痛點 P2：多管道人工彙整易漏件／重工"]:::pain -.-> O2
    P3["痛點 P3：試算表人工排位有重複格位風險"]:::pain -.-> D3
    P4["痛點 P4：臨時異動需改多份，版本易不同步"]:::pain -.-> O9
    P5["痛點 P5：公告與現場不一致，迷路並增加詢問"]:::pain -.-> D5

    classDef pain fill:#fff1f2,stroke:#be123c,stroke-width:2px,color:#881337;
    classDef decision fill:#fffbeb,stroke:#d97706,stroke-width:2px,color:#451a03;
    class D1,D2,D3,D4,D5,D6,C4,C5 decision;
